# Gemini Developer API key, used server-side only by api/ai-crop.ts (a Vercel serverless
# function). Never prefix this with VITE_ — that would bundle it into the client JS.
GEMINI_API_KEY=

# Present in this project's .env but currently unused by the AI-crop feature, which
# authenticates with a plain Gemini Developer API key rather than a GCP/Vertex-scoped
# project. Leave blank unless project-scoped/Vertex AI auth is wired up later.
GEMINI_PROJECT_NAME=
GEMINI_PROJECT_ID=
